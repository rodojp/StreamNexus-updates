{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stream-nexus",
  "compatibility_date": "2026-06-12",
  "main": "./src/worker.js",
  "workers_dev": false,
  "preview_urls": false,
  "keep_vars": true,
  "observability": {
    "enabled": true,
    "logs": {
      "invocation_logs": true,
      "head_sampling_rate": 1
    }
  },
  "routes": [
    {
      "pattern": "stream-nexus.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "force-trailing-slash",
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      "binding": "CONTACT_DB",
      "database_name": "stream-nexus-contact",
      "database_id": "b8fb6093-c778-45b5-909e-9bee1efacdab"
    }
  ],
  "r2_buckets": [
    {
      "binding": "CONTACT_ATTACHMENTS",
      "bucket_name": "stream-nexus-contact-attachments"
    }
  ],
  "vars": {
    "CONTACT_ATTACHMENT_RETENTION_DAYS": "90",
    "CONTACT_ATTACHMENT_STORAGE_LIMIT_BYTES": "8589934592",
    "CONTACT_RETENTION_DAYS": "180",
    "TURNSTILE_SITE_KEY": "0x4AAAAAADnzTQEQOOyfaWrU"
  },
  "triggers": {
    "crons": [
      "17 3 * * *"
    ]
  }
}
